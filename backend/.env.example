# Copier sur le VPS : cp .env.example .env puis remplir les valeurs

SECRET_KEY=changez-moi-avec-une-cle-secrete-longue-et-longue
DATABASE_URL=postgresql://cro:cro_secret_2024@localhost:5434/stock_cro

# =============================================================================
# EMAIL — le client recoit le code sur SON adresse (Gmail, Yahoo, etc.)
# =============================================================================
# 1. Creer une adresse sur Hostinger hPanel → Emails (ex: noreply@votredomaine.com)
# 2. Remplir SMTP_USER et SMTP_PASSWORD ci-dessous
# 3. Mettre EMAIL_DEV_MODE=false
# 4. Redemarrer : docker compose up --build -d

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=noreply@votredomaine.com
SMTP_PASSWORD=mot_de_passe_de_la_boite_email
SMTP_FROM=Conseil Regional Ouest <noreply@votredomaine.com>

# Port 465 (SSL) au lieu de 587 : mettre SMTP_PORT=465 et SMTP_USE_SSL=true
SMTP_USE_SSL=false

# false = envoi reel vers la boite mail du client
EMAIL_DEV_MODE=false

FRONTEND_URL=http://145.223.121.38:5181
UPLOAD_DIR=./uploads
