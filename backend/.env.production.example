# Copier sur le VPS :
#   cp backend/.env.production.example backend/.env
#   nano backend/.env
# Puis : docker compose up --build -d
#
# SECURITE : ne mettez PAS votre boite mail personnelle ici.
# Creez une adresse DEDIEE a l'application (ex: noreply@votredomaine.com).
# Seul le serveur connait ce mot de passe — les utilisateurs de l'app ne le voient jamais.
# Ce fichier n'est jamais sur GitHub (.gitignore).

SECRET_KEY=remplacez-par-une-cle-secrete-tres-longue
FRONTEND_URL=http://145.223.121.38:5181

# --- Hostinger hPanel → Emails → Creer une NOUVELLE adresse (pas la votre) ---
# Exemple : noreply@votredomaine.com ou stock@votredomaine.com
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=noreply@votredomaine.com
SMTP_PASSWORD=mot_de_passe_de_cette_boite_dediee_uniquement
SMTP_FROM=Conseil Regional Ouest <noreply@votredomaine.com>
SMTP_USE_SSL=false

# false = le client recoit le code sur SON email (Gmail, Yahoo, etc.)
EMAIL_DEV_MODE=false

UPLOAD_DIR=./uploads
